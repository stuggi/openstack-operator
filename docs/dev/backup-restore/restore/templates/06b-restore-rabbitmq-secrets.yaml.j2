---
# RabbitMQ Credential Restore
# Restores all secrets from the backup to a temporary namespace so that
# the original *-default-user secrets can be copied as *-restored-user
# into the target namespace.
apiVersion: velero.io/v1
kind: Restore
metadata:
  name: openstack-restore-rabbitmq-secrets-{{ restore_suffix }}
  namespace: {{ oadp_namespace }}
spec:
  backupName: {{ resources_backup_name }}
  includedNamespaces:
  - {{ openstack_namespace }}
  namespaceMapping:
    {{ openstack_namespace }}: openstack-restore-tmp
  includedResources:
  - secrets
  resourceModifier:
    kind: ConfigMap
    name: openstack-restore-tmp-resource-modifiers

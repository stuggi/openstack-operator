---
# Restore Order 40: Backup Configuration, IP Sets & DataPlane Services
# Restores GaleraBackup, IPSet, and DataPlaneService CRs
# Must be restored after OpenStackControlPlane (order 30)
apiVersion: velero.io/v1
kind: Restore
metadata:
  name: openstack-restore-40-backup-{{ restore_suffix }}
  namespace: {{ oadp_namespace }}
spec:
  backupName: {{ resources_backup_name }}
  includedNamespaces:
  - {{ openstack_namespace }}
  labelSelector:
    matchLabels:
      backup.openstack.org/restore: "true"
      backup.openstack.org/restore-order: "40"
  resourceModifier:
    kind: ConfigMap
    name: openstack-restore-resource-modifiers

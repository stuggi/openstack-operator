---
# Restore Order 20: Infrastructure CRs
# Restores OpenStackVersion, OpenStackBackupConfig, MariaDBAccount,
# MariaDBDatabase, NetConfig, Topology, BGPConfiguration, DNSData, InstanceHa
# Must be restored before OpenStackControlPlane
#
# Note: InstanceHa is restored with spec.disabled=True (via resource modifier)
# to prevent fencing EDPM nodes before they reconnect.
apiVersion: velero.io/v1
kind: Restore
metadata:
  name: openstack-restore-20-infra-{{ restore_suffix }}
  namespace: {{ oadp_namespace }}
spec:
  backupName: {{ resources_backup_name }}
  includedNamespaces:
  - {{ openstack_namespace }}
  labelSelector:
    matchLabels:
      backup.openstack.org/restore: "true"
      backup.openstack.org/restore-order: "20"
  resourceModifier:
    kind: ConfigMap
    name: openstack-restore-resource-modifiers

---
# Restore Order 30: OpenStackControlPlane (Staged)
# Restores the OpenStackControlPlane CR with deployment-stage annotation
# added by the resource modifier. Only infrastructure services start initially.
# Must be restored after infrastructure CRs (order 20)
apiVersion: velero.io/v1
kind: Restore
metadata:
  name: openstack-restore-30-ctlplane-{{ restore_suffix }}
  namespace: {{ oadp_namespace }}
spec:
  backupName: {{ resources_backup_name }}
  includedNamespaces:
  - {{ openstack_namespace }}
  labelSelector:
    matchLabels:
      backup.openstack.org/restore: "true"
      backup.openstack.org/restore-order: "30"
  resourceModifier:
    kind: ConfigMap
    name: openstack-restore-resource-modifiers

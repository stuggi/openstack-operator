---
# OpenStack PVC Backup
# Backs up PVCs labeled with backup.openstack.org/backup=true using CSI snapshots.
# Velero automatically includes bound PVs — no need to label PVs separately.
#
# Variables:
#   backup_name_suffix: Timestamp suffix for backup name
#   oadp_namespace: OADP namespace (default: openshift-adp)
#   openstack_namespace: OpenStack namespace (default: openstack)
#   storage_location: Velero storage location (default: velero-1)
#   backup_ttl: Backup retention (default: 720h)
#   snapshot_move_data: Upload snapshots to BSL via Data Mover (default: true)
#
# When snapshot_move_data is true, OADP uploads CSI snapshot data to the
# BackupStorageLocation (S3/MinIO) via Kopia, enabling restore after total
# cluster loss. Requires OADP DPA with nodeAgent enabled and uploaderType: kopia.
apiVersion: velero.io/v1
kind: Backup
metadata:
  name: openstack-backup-pvcs-{{ backup_name_suffix }}
  namespace: {{ oadp_namespace }}
spec:
  includedNamespaces:
  - {{ openstack_namespace }}
  labelSelector:
    matchLabels:
      backup.openstack.org/backup: "true"
  snapshotVolumes: true
  defaultVolumesToFsBackup: false
{% if snapshot_move_data | default(true) | bool %}
  snapshotMoveData: true
{% endif %}
  volumeSnapshotLocations: []
  storageLocation: {{ storage_location }}
  ttl: {{ backup_ttl }}
